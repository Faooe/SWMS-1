{
  "version": 2,
  "framework": null,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/(css|js|images|assets)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/lottie/(.*)",
      "dest": "/public/lottie/$1"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "true",
    "APP_URL": "https://swms-1.vercel.app",
    "ASSET_URL": "https://swms-1.vercel.app",
    "VIEW_COMPILED_PATH": "/tmp",
    "CACHE_STORE": "array",
    "CACHE_DRIVER": "array",
    "SESSION_DRIVER": "cookie",
    "LOG_CHANNEL": "stderr",
    "APP_CONFIG_CACHE": "/tmp/config.php",
    "APP_EVENTS_CACHE": "/tmp/events.php",
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_ROUTES_CACHE": "/tmp/routes.php",
    "APP_SERVICES_CACHE": "/tmp/services.php"
  },
    "crons": [
    {
      "path": "/cron/mark-absent",
      "schedule": "59 16 * * *"
    },
    {
      "path": "/cron/subscriptions-downgrade",
      "schedule": "5 17 * * *"
    },
    {
      "path": "/cron/activate-assignments",
      "schedule": "0 23 * * *"
    }
  ]
}